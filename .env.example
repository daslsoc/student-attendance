APP_NAME="Attendance System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8089

# --- Production checklist (see docs/deployment.md) ---
# In the production .env (which lives on the server, never committed) set:
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://your-domain        # HTTPS, matches the served host
#   SESSION_SECURE_COOKIE=true         # cookies only over HTTPS
# and a real APP_KEY (php artisan key:generate).

# --- Student-registration integration (see docs/integration.md) ---
# Base URL of the registration app and the shared bearer token (must equal
# INTEGRATION_API_TOKEN there).
#   Local dev: http://host.docker.internal:8090 (registration's published port;
#              the app container has a host-gateway mapping for this host).
#   Production: the registration app's HTTPS URL, e.g. https://registration.example
REGISTRATION_API_URL=http://host.docker.internal:8090
REGISTRATION_API_TOKEN=
# Override only if your Subject rows aren't named "Buddhism" / "Sinhala":
# INTEGRATION_DHAMMA_SUBJECT=Buddhism
# INTEGRATION_SINHALA_SUBJECT=Sinhala

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- App-specific config (config/custom.php) ---
# How long a magic login link stays valid, in hours.
TOKEN_EXPIRY_HOURS=4
# Name shown to teachers for the managing team.
MANAGEMENT_TEAM_NAME="Dhamma and Sinhala Management Team"
